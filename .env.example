# ── PostgreSQL ─────────────────────────────────────────────────
# Mot de passe commun utilisé par Docker Compose pour le service db + backend
POSTGRES_PASSWORD=change_this_password

# ── Backend Go ─────────────────────────────────────────────────
JWT_SECRET=change_this_to_a_long_random_secret_min_32_chars
ADMIN_SECRET=change_this_admin_secret

# Origines autorisées pour CORS (séparées par des virgules)
ALLOWED_ORIGIN=http://localhost:3000,http://localhost:3001,http://localhost:5173

# ── SMTP (optionnel — désactiver en dev local) ─────────────────
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your@email.com
SMTP_PASS=your_smtp_password
SMTP_FROM=noreply@fisca.bf

# ── Dashboard Next.js ──────────────────────────────────────────
# URL du backend, accessible depuis le NAVIGATEUR (pas le conteneur)
NEXT_PUBLIC_API_URL=http://localhost:8080

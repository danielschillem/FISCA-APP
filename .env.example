# ── PostgreSQL ─────────────────────────────────────────────────
# Mot de passe commun utilisé par Docker Compose pour le service db + backend
POSTGRES_PASSWORD=change_this_password

# ── Backend Go ─────────────────────────────────────────────────
# DB locale Docker (dev). En production, Render injecte sa propre DATABASE_URL (Neon).
DATABASE_URL=postgres://fisca:change_this_password@db:5432/fisca_dev?sslmode=disable
JWT_SECRET=change_this_to_a_long_random_secret_min_32_chars
ADMIN_SECRET=change_this_admin_secret
SUPERADMIN_EMAIL=
SUPERADMIN_PASSWORD=

# Origines autorisées pour CORS (séparées par des virgules)
ALLOWED_ORIGIN=http://localhost:3000,http://localhost:5173

# ── SMTP (optionnel — désactiver en dev local) ─────────────────
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your@email.com
SMTP_PASS=your_smtp_password
SMTP_FROM=noreply@fisca.bf

# ── OpenAI (optionnel — module assistant IA) ──────────────────
OPENAI_API_KEY=sk-...

# ── Frontend Vite ─────────────────────────────────────────────
# URL du backend accessible depuis le navigateur (prod uniquement)
# En dev local, laisser vide : le proxy Vite /api → localhost:8080 s'en charge
VITE_API_URL=
# URL cible du proxy Vite en dev (si le backend tourne sur un autre port)
VITE_API_PROXY_TARGET=http://localhost:8080
# Bypass paiement Orange Money en développement (true/false)
VITE_BYPASS_PAYMENT=true

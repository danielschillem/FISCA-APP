{
    "framework": "nextjs",
    "regions": [
        "cdg1"
    ],
    "installCommand": "npm ci",
    "buildCommand": "npm run build",
    "headers": [
        {
            "source": "/api/(.*)",
            "headers": [
                {
                    "key": "Cache-Control",
                    "value": "no-store"
                }
            ]
        }
    ]
}
# ── Base de données ────────────────────────────────────────────
DATABASE_URL=postgres://fisca:password@localhost:5432/fisca_dev?sslmode=disable

# ── Serveur ────────────────────────────────────────────────────
PORT=8080
JWT_SECRET=change_this_to_a_long_random_secret_min_32_chars
ADMIN_SECRET=change_this_admin_secret

# Origines autorisées pour CORS (séparées par des virgules)
ALLOWED_ORIGIN=http://localhost:3000,http://localhost:3001,http://localhost:5173

# ── SMTP ───────────────────────────────────────────────────────
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your@email.com
SMTP_PASS=your_smtp_password
SMTP_FROM=noreply@fisca.bf
